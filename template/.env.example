# Loaded automatically by docker compose. NEVER committed.

# Name of this project stack. Must be a lowercase slug: ^[a-z][a-z0-9-]*$
PROJECT={{.Project}}

# Pinned devtools image tag. `dev bump {{.Project}}` updates this.
# Use `latest` for moving-target dev; pin to a date (e.g. 2026-04-23)
# for reproducible spin-ups.
DEVTOOLS_TAG={{.DevtoolsTag}}

# Optional per-service overrides (uncomment when you enable the services).
# MAILPIT_WEB_PORT=8025
