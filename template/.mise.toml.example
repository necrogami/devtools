# Rename to .mise.toml and drop inside /code at the project root.
# mise will install the listed runtimes at first `dev shell` and make them
# available on PATH. Versions get pinned per-project and never leak across
# projects (each project has its own /home volume, except for the shared
# mise install-cache volume which only dedupes downloads).
#
# See https://mise.jdx.dev for the full reference.

[tools]
# node   = "22"
# php    = "8.3"
# go     = "1.25"
# rust   = "stable"
# python = "3.13"
# bun    = "latest"
# deno   = "latest"
# terraform = "latest"
# kubectl   = "latest"
# helm      = "latest"

[env]
# Uncomment to wire project-specific env vars that load on shell activation.
# APP_ENV = "development"
# DATABASE_URL = "mysql://root:root@db:3306/myproject"
