# Per-project stacks live here and carry .env + compose overrides that are
# specific to a deployment. They're intentionally never part of this repo.
/projects/*
!/projects/.gitkeep

# Build artifacts
/dev
/dev-*
/dist/
*.test
*.out
coverage.*

# Env files (never commit real env files anywhere in repo)
.env
*.env.local

# Go tool caches (if running tests locally)
/go.work
/go.work.sum

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Personal working notes — local status snapshots, backlog, scratch plans.
# This repo is public; these stay on the maintainer's machine only.
TODO.md
NOTES.md
SCRATCH.md
*.local.md
